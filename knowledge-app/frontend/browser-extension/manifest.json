{
  "manifest_version": 3,
  "name": "Knowledge Saver",
  "version": "1.0.0",
  "description": "Save anything from the web to your knowledge base",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Knowledge Saver"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}